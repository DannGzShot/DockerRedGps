    "your_mysql_user",
    "your_mysql_password",
}


class Wizard:
    def __init__(self, args: argparse.Namespace) -> None:
        self.args = args
        self.root = Path(__file__).resolve().parents[2]
        self.step_number = 0
        self.actions_taken: List[str] = []
        self.warnings: List[str] = []
        self.failures: List[str] = []
        self.system = platform.system()
        self.uid = os.getuid() if hasattr(os, "getuid") else None
        self.gid = os.getgid() if hasattr(os, "getgid") else None
        os.chdir(self.root)

    def say(self, message: str = "") -> None:
        print(message, flush=True)

    def step(self, title: str) -> None:
        self.step_number += 1
        self.say("")
        self.say(f"[{self.step_number}] {title}")

    def ok(self, message: str) -> None:
        self.say(f"  OK: {message}")

    def info(self, message: str) -> None:
        self.say(f"  INFO: {message}")

    def warn(self, message: str) -> None:
        self.warnings.append(message)
        self.say(f"  AVISO: {message}")

    def fail(self, message: str) -> None:
        self.failures.append(message)
        self.say(f"  ERROR: {message}")

    def action(self, message: str) -> None:
        self.actions_taken.append(message)
        self.say(f"  ACCION: {message}")

    def rel(self, path: str) -> Path:
        return self.root / path

    def command_exists(self, command: str) -> bool:
        return shutil.which(command) is not None

    def run(
        self,
        cmd: Sequence[str],
        *,
        input_text: Optional[str] = None,
        timeout: int = 60,
    ) -> subprocess.CompletedProcess:
        try:
            return subprocess.run(
                list(cmd),
                input=input_text,
                cwd=str(self.root),
                text=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                timeout=timeout,
                check=False,
            )
        except FileNotFoundError:
            return subprocess.CompletedProcess(list(cmd), 127, "", "command not found")
        except subprocess.TimeoutExpired as exc:
            return subprocess.CompletedProcess(list(cmd), 124, exc.stdout or "", exc.stderr or "timeout")

    def ask(self, prompt: str, default: bool = False) -> bool:
        if self.args.dry_run or self.args.doctor_only:
            self.info(f"dry-run: {prompt}")
            return False
        if self.args.yes:
            self.info(f"auto-yes: {prompt}")
            return True
        if not sys.stdin.isatty():
            self.warn(f"No hay terminal interactiva. Omite: {prompt}")
            return False
        suffix = " [S/n] " if default else " [s/N] "
        answer = input(prompt + suffix).strip().lower()
        if not answer:
            return default
        return answer in {"s", "si", "y", "yes"}

    def sudo_cmd(self, cmd: Sequence[str]) -> List[str]:
        if self.uid == 0:
            return list(cmd)
        return ["sudo", *cmd]

    def write_text(self, path: Path, content: str) -> None:
        path.write_text(content, encoding="utf-8")

    def read_text(self, path: Path) -> str:
        return path.read_text(encoding="utf-8", errors="replace")

    def parse_env(self) -> Dict[str, str]:
        env_path = self.rel(".env")
        values: Dict[str, str] = {}
        if not env_path.exists():
            return values
        for line in self.read_text(env_path).splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith("#") or "=" not in stripped:
                continue
            key, value = stripped.split("=", 1)
            values[key.strip()] = value.strip().strip("'\"")
        return values

    def ensure_dir(self, path: Path) -> None:
        if path.exists():
            return
        if self.args.dry_run or self.args.doctor_only:
            self.info(f"crearia carpeta {path.relative_to(self.root)}")
            return
        path.mkdir(parents=True, exist_ok=True)
        self.action(f"Carpeta creada: {path.relative_to(self.root)}")

    def run_make(
        self,
        target: str,
        *,
        needs_sudo: bool = False,
        show_output: bool = False,
        timeout: int = 180,
    ) -> bool:
        cmd = ["make", target]
        if needs_sudo and self.args.skip_sudo:
            self.warn(f"Se requiere sudo para make {target}; omitido por --skip-sudo.")
            return False
        if needs_sudo and self.uid != 0:
            authorization = self.run(["sudo", "-v"], timeout=60)
            if authorization.returncode != 0:
                self.warn(f"No se pudo autorizar sudo para make {target}: {last_line(authorization.stderr)}")
                self.info(f"Ejecuta make {target} directamente en otra terminal y vuelve a iniciar el asistente.")
                return False
        result = self.run(cmd, timeout=timeout)
        if result.returncode == 0:
            self.action(f"Ejecutado: make {target}")
            if show_output:
                self.emit_output_tail(result.stdout, result.stderr, limit=18)
            return True
        else:
            self.warn(f"Fallo make {target}: {last_line(result.stderr or result.stdout)}")
            self.emit_output_tail(result.stdout, result.stderr, limit=18)
            if target == "install-tools":
                self.info("Ejecuta make install-tools directamente en otra terminal y vuelve a iniciar el asistente.")
            return False

    def emit_output_tail(self, stdout: str, stderr: str, *, limit: int = 12) -> None:
        lines = [line.rstrip() for line in (stdout + "\n" + stderr).splitlines() if line.strip()]
        if not lines:
            return
        if len(lines) > limit:
            self.info(f"Ultimas {limit} lineas de salida:")
        else:
            self.info("Salida del comando:")
        for line in lines[-limit:]:
            self.say(f"    {line[:260]}")

    def check_os_and_tools(self) -> None:
        self.step("Revisando sistema y herramientas")
        if self.system in {"Linux", "Darwin"}:
            self.ok(f"Sistema soportado: {self.system}")
        else:
            self.fail(f"Sistema no soportado para este instalador: {self.system}")

        for command in ["docker", "ssh", "openssl"]:
            if self.command_exists(command):
                self.ok(f"{command} disponible")
            else:
                self.warn(f"Falta {command}")

        if self.command_exists("curl") or self.command_exists("wget"):
            self.ok("curl o wget disponible")
        else:
            self.warn("Falta curl o wget")

        missing_aux = [cmd for cmd in ["openssl", "sshuttle"] if not self.command_exists(cmd)]
        if not (self.command_exists("curl") or self.command_exists("wget")):
            missing_aux.append("curl-o-wget")
        if self.command_exists("sshuttle"):
            self.ok("sshuttle disponible")
        else:
            self.warn("Falta sshuttle. Ejecuta make install-tools.")

        if missing_aux and self.ask("Instalar herramientas auxiliares con make install-tools?"):
            self.run_make("install-tools", needs_sudo=(self.system == "Linux"), show_output=True)

        if not self.command_exists("docker"):
            self.warn("Docker no esta instalado o no esta en PATH.")
            self.info("Instala Docker antes de levantar contenedores. La documentacion incluye pasos para Linux y macOS.")
            return

        info = self.run(["docker", "info"], timeout=20)
        if info.returncode == 0:
            self.ok("Docker responde con el usuario actual")
        else:
            self.warn("Docker no responde con el usuario actual.")
            if self.system == "Linux":
                self.explain_linux_docker_permissions()
            elif self.system == "Darwin":
                self.info("En macOS abre Docker y espera a que termine de iniciar.")

        compose = self.run(["docker", "compose", "version"], timeout=20)
        if compose.returncode == 0:
            self.ok(compose.stdout.strip())
        else:
            self.warn("Docker Compose v2 no esta disponible.")

    def explain_linux_docker_permissions(self) -> None:
        user = os.environ.get("USER", "")
        groups = self.run(["id", "-nG"], timeout=10)
        group_names = set(groups.stdout.strip().split()) if groups.returncode == 0 else set()
        if "docker" not in group_names:
            self.warn(f"El usuario {user or '<usuario>'} no pertenece al grupo docker.")
            if user and self.ask(f"Agregar {user} al grupo docker con sudo?"):
                result = self.run(self.sudo_cmd(["usermod", "-aG", "docker", user]), timeout=60)
                if result.returncode == 0:
                    self.action(f"Usuario agregado al grupo docker: {user}")
                    self.info("Cierra esta terminal y abre una nueva para que el grupo aplique.")
                else:
                    self.warn(f"No se pudo agregar al grupo docker: {last_line(result.stderr)}")
        else:
            self.info("El usuario esta en el grupo docker; abre una terminal nueva o reinicia la sesion si Docker sigue pidiendo sudo.")
        self.info("Evita levantar el proyecto con sudo docker compose; eso puede crear archivos con owner root.")

    def check_project_structure(self) -> None:
        self.step("Revisando estructura del proyecto")
        for path in DOCKER_DIRS:
            target = self.rel(path)
            if target.exists():
                self.ok(f"Existe {path}")
            else:
                self.warn(f"Falta carpeta Docker local {path}")
                if self.ask(f"Crear carpeta {path}?"):
                    self.ensure_dir(target)

        missing: List[str] = []
        for path in APP_REQUIRED_PATHS:
            target = self.rel(path)
            if target.exists():
                self.ok(f"Ruta de aplicacion encontrada: {path}")
            else:
                missing.append(path)
                self.warn(f"Falta ruta de aplicacion: {path}")

        if missing:
            self.info("No creare dev/ ni qa/ automaticamente. Esos repos deben clonarse o renombrarse manualmente.")
        else:
            self.ok("Estructura base de aplicaciones completa")

        optional_missing = [path for path in APP_OPTIONAL_PATHS if not self.rel(path).exists()]
        optional_present = [path for path in APP_OPTIONAL_PATHS if self.rel(path).exists()]
        if optional_present:
            self.info("Repos auxiliares encontrados: " + ", ".join(optional_present))
        if optional_missing:
            self.info(
                "Repos auxiliares no montados por este docker-compose: "
                + ", ".join(optional_missing)
                + ". Clonalos solo si tu flujo los usa directamente."
            )

    def check_env_files(self) -> None:
        self.step("Revisando archivos locales y plantillas")
        env_path = self.rel(".env")
        env_example = self.rel(".env.example")
        if env_path.exists():
            self.ok(".env existe")
        elif env_example.exists():
            self.warn("Falta .env")
            if self.ask("Crear .env desde .env.example?"):
                shutil.copy2(env_example, env_path)
                self.action("Creado .env desde .env.example")
        else:
            self.fail("Faltan .env y .env.example")

        env_values = self.parse_env()
        if env_values:
            for key in ["SSHUTTLE_REMOTE", "SSH_TUNNEL_HOST"]:
                value = env_values.get(key, "")
                if not value:
                    if key == "SSHUTTLE_REMOTE":
                        self.info("SSHUTTLE_REMOTE no esta definido en .env; se usara qa por defecto")
                    else:
                        self.warn(f"{key} no esta definido en .env")
                elif value in PLACEHOLDER_VALUES:
                    self.warn(f"{key} sigue con valor de ejemplo: {value}")
                else:
                    self.ok(f"{key} definido")
            for key in ["SSH_TUNNEL_EXCLUDE_HOST", "SSH_TUNNEL_EXCLUDE_PORT"]:
                value = env_values.get(key, "")
                if value:
                    self.ok(f"{key} definido manualmente")
                else:
                    self.info(f"{key} no esta definido; make vpn-qa lo calculara desde ~/.ssh/config")

        redis_real = self.rel("docker/php/redisCache.ini")
        redis_example = self.rel("docker/php/redisCache.ini.example")
        if redis_real.exists():
            self.ok("docker/php/redisCache.ini existe")
        elif redis_example.exists():
            self.warn("Falta docker/php/redisCache.ini")
            if self.ask("Crear docker/php/redisCache.ini desde la plantilla example?"):
                shutil.copy2(redis_example, redis_real)
                self.action("Creado docker/php/redisCache.ini desde .example")
                self.warn("Edita docker/php/redisCache.ini con valores autorizados antes de usar Redis remoto.")
        else:
            self.warn("Falta docker/php/redisCache.ini.example")

        general_real = self.rel("docker/var-cache/config/general.cfg")
        general_example = self.rel("docker/var-cache/config/general.cfg.example")
        if general_real.exists():
            self.ok("docker/var-cache/config/general.cfg existe")
        elif general_example.exists():
            self.info("general.cfg real no existe; se puede crear si tu entorno lo requiere.")

    def check_hosts(self) -> None:
        self.step("Revisando /etc/hosts")
        hosts_path = Path("/etc/hosts")
        try:
            content = hosts_path.read_text(encoding="utf-8", errors="replace")
        except OSError as exc:
            self.warn(f"No se pudo leer /etc/hosts: {exc}")
            return

        missing = [host for host in EXPECTED_HOSTS if host not in content]
        if not missing:
            self.ok("Hosts locales ya estan presentes")
            return

        self.warn("Faltan hosts locales: " + ", ".join(missing))
        block = "\n# REDGPS Docker local\n" + "\n".join(f"127.0.0.1 {host}" for host in missing) + "\n"
        if self.args.skip_sudo:
            self.warn("No se modificara /etc/hosts por --skip-sudo.")
            self.info(block.strip())
            return
        if self.ask("Agregar hosts faltantes a /etc/hosts con sudo?"):
            result = self.run(self.sudo_cmd(["tee", "-a", "/etc/hosts"]), input_text=block, timeout=30)
            if result.returncode == 0:
                self.action("Hosts locales agregados a /etc/hosts")
            else:
                self.warn(f"No se pudo actualizar /etc/hosts: {last_line(result.stderr)}")

    def check_certs(self) -> None:
        self.step("Revisando certificados HTTPS locales")
        cert = self.rel("docker/apache/certs/dev.redgps.local.crt")
        key = self.rel("docker/apache/certs/dev.redgps.local.key")
        ca = self.rel("docker/apache/certs/redgps-local-dev-ca.crt")

        if cert.exists() and key.exists() and ca.exists():
            self.ok("Certificados locales existen")
        else:
            self.warn("Faltan certificados locales")
            if self.ask("Generar certificados con make certs?"):
                self.run_make("certs")

        if ca.exists():
            if self.ca_is_installed(ca):
                self.ok("CA local parece instalada en el sistema")
            else:
                self.warn("La CA local no parece instalada o no pude confirmarlo")
                if not self.args.skip_sudo and self.ask("Instalar CA local con make certs-install?"):
                    self.run_make("certs-install", needs_sudo=True)
                elif self.args.skip_sudo:
                    self.info("Ejecuta make certs-install cuando puedas usar sudo.")
            if self.system == "Linux":
                if self.nss_ca_is_installed(ca):
                    self.ok("CA local parece instalada en NSS para Chrome/Chromium")
                elif self.command_exists("certutil"):
                    self.warn("La CA local no aparece en NSS; Chrome/Chromium puede mostrar el certificado en rojo.")
                    if not self.args.skip_sudo and self.ask("Instalar CA en sistema y NSS con make certs-install-linux?"):
                        self.run_make("certs-install-linux", needs_sudo=True)
                    elif self.args.skip_sudo:
                        self.info("Ejecuta make certs-install-linux y reinicia el navegador.")
                else:
                    self.warn(
                        "certutil no esta instalado; si Chrome/Chromium marca el certificado en rojo, "
                        "hace falta instalar herramientas NSS."
                    )
                    if self.args.skip_sudo:
                        self.info("Ejecuta make install-tools y make certs-install-linux cuando puedas usar sudo.")
                    elif self.ask("Instalar herramientas con make install-tools?"):
                        self.run_make("install-tools", needs_sudo=True, show_output=True)
                        if self.command_exists("certutil"):
                            if self.ask("Instalar CA en sistema y NSS con make certs-install-linux?"):
                                self.run_make("certs-install-linux", needs_sudo=True)
                        else:
                            self.warn(
                                "certutil sigue sin estar disponible. Instala libnss3-tools/nss-tools "
                                "y vuelve a ejecutar make certs-install-linux."
                            )

    def ca_is_installed(self, ca: Path) -> bool:
        if self.system == "Linux":
            installed = Path("/usr/local/share/ca-certificates/redgps-local-dev-ca.crt")
            return installed.exists()
        if self.system == "Darwin" and self.command_exists("security"):
            result = self.run(
                ["security", "find-certificate", "-c", "redgps-local-dev-ca", "/Library/Keychains/System.keychain"],
                timeout=20,
            )
            return result.returncode == 0
        return False

    def nss_ca_is_installed(self, ca: Path) -> bool:
        if self.system != "Linux" or not self.command_exists("certutil"):
            return False
        nss_db = Path.home() / ".pki" / "nssdb"
        if not (nss_db / "cert9.db").exists():
            return False
        try:
            expected_fingerprint = certificate_fingerprint(ca.read_text(encoding="utf-8"))
        except OSError:
            return False
        if expected_fingerprint is None:
            return False

        certificates = self.run(["certutil", "-L", "-d", f"sql:{nss_db}"], timeout=20)
        if certificates.returncode != 0:
            return False
        for nickname in nss_certificate_nicknames(certificates.stdout):
            certificate = self.run(
                ["certutil", "-L", "-d", f"sql:{nss_db}", "-n", nickname, "-a"],
                timeout=20,
            )
            if certificate.returncode == 0 and certificate_fingerprint(certificate.stdout) == expected_fingerprint:
                return True
        return False

    def check_vhosts_and_htaccess(self) -> None:
        self.step("Revisando VirtualHosts Docker y .htaccess de aplicaciones")
        for path in BACKEND_VHOST_FILES:
            target = self.rel(path)
            if not target.exists():
                self.fail(f"Falta {path}")
                continue
            content = self.read_text(target)
            if "AllowOverride All" in content:
                self.warn(f"{path} permite .htaccess de aplicacion en Docker local")
                if self.ask(f"Cambiar AllowOverride All a AllowOverride None en {path}?"):
                    self.write_text(target, content.replace("AllowOverride All", "AllowOverride None"))
                    self.action(f"Actualizado {path} para ignorar .htaccess en Docker local")
            elif "AllowOverride None" in content:
                self.ok(f"{path} ignora .htaccess en Docker local")
            else:
                self.warn(f"{path} no contiene AllowOverride explicito")

        htaccess_problem_envs = self.scan_app_htaccess()
        self.info("No se modifican .htaccess de dev/qa directamente. Si estan viejos, se actualizan via git pull.")
        if "qa" in htaccess_problem_envs and self.ask("Actualizar repos QA con make app-repos-pull-qa?"):
            if self.run_make("app-repos-pull-qa", show_output=True, timeout=300):
                after = self.scan_app_htaccess(emit=False)
                if "qa" in after:
                    self.warn("QA sigue con .htaccess problematico despues del pull. Revisa branch/upstream/conflictos en qa/partners.")
                else:
                    self.ok("Repos QA ya no contienen .htaccess problematico")
        if "dev" in htaccess_problem_envs and self.ask("Actualizar repos DEV con make app-repos-pull-dev?"):
            if self.run_make("app-repos-pull-dev", show_output=True, timeout=300):
                after = self.scan_app_htaccess(emit=False)
                if "dev" in after:
                    self.warn("DEV sigue con .htaccess problematico despues del pull. Revisa branch/upstream/conflictos en dev/redgps o dev/partners.")
                else:
                    self.ok("Repos DEV ya no contienen .htaccess problematico")

    def scan_app_htaccess(self, *, emit: bool = True) -> set:
        htaccess_problem_envs = set()
        for path in APP_HTACCESS_FILES:
            target = self.rel(path)
            if not target.exists():
                if emit:
                    self.warn(f"No existe {path}")
                continue
            content = self.read_text(target)
            if emit and "RewriteEngine" not in content:
                self.warn(f"{path} no contiene RewriteEngine")
            if "SetEnvIfNoCase ^(" in content or "Accept-EncodXng" in content:
                env_name = path.split("/", 1)[0]
                if env_name in {"dev", "qa"}:
                    htaccess_problem_envs.add(env_name)
                if emit:
                    self.warn(
                        f"{path} contiene una regla SetEnvIfNoCase que puede fallar en Apache 2.4. "
                        "Docker local debe quedar protegido con AllowOverride None."
                    )
            elif emit:
                self.ok(f"{path} no contiene la regla SetEnvIfNoCase problematica")
        return htaccess_problem_envs

    def check_permissions(self) -> None:
        self.step("Revisando propietarios y permisos")
        if self.uid is None or self.gid is None:
            self.warn("No se puede revisar UID/GID en este sistema.")
            return

        local_bad = self.find_non_owner(LOCAL_PERMISSION_PATHS, recursive=True, limit=30)
        dataservice_bad = self.find_non_owner(["dataservice"], recursive=False, limit=5)
        app_bad = self.find_non_owner(APP_PERMISSION_PATHS, recursive=False, limit=30)

        if not local_bad:
            self.ok("Archivos locales Docker revisados tienen propietario esperado")
        else:
            self.warn("Hay archivos locales Docker que no pertenecen al usuario actual:")
            for item in local_bad:
                self.say(f"    {item}")
            if self.args.skip_sudo:
                self.info("Omitido ajuste de permisos por --skip-sudo.")
            elif self.ask("Ajustar propietario en rutas locales Docker con sudo chown?"):
                self.chown_local_paths()

        if dataservice_bad:
            self.warn("dataservice no pertenece al usuario actual:")
            for item in dataservice_bad:
                self.say(f"    {item}")
            if self.args.skip_sudo:
                self.info("Omitido ajuste de dataservice por --skip-sudo.")
            elif self.ask("Ajustar propietario de dataservice con sudo chown?"):
                self.chown_paths(["dataservice"], "Permisos ajustados en dataservice")
        else:
            self.ok("dataservice tiene propietario esperado")

        if app_bad:
            self.warn("Hay archivos criticos de aplicacion que no pertenecen al usuario actual:")
            for item in app_bad:
                self.say(f"    {item}")
            self.info("No ajusto permisos dentro de dev/qa automaticamente. Revisalo con el responsable del repo.")
        else:
            self.ok("Archivos criticos de aplicacion revisados tienen propietario esperado")

    def find_non_owner(self, paths: Iterable[str], *, recursive: bool, limit: int) -> List[str]:
        bad: List[str] = []
        for rel_path in paths:
            start = self.rel(rel_path)
            if not start.exists():
                continue
            candidates: Iterable[Path]
            if recursive and start.is_dir():
                candidates = walk_limited(start, limit * 3)
            else:
                candidates = [start]
            for path in candidates:
                try:
                    stat = path.stat()
                except OSError:
                    continue
                if stat.st_uid != self.uid:
                    bad.append(f"{path.relative_to(self.root)} owner_uid={stat.st_uid}")
                    if len(bad) >= limit:
                        bad.append("... mas archivos omitidos")
                        return bad
        return bad

    def chown_local_paths(self) -> None:
        self.chown_paths(LOCAL_PERMISSION_PATHS, "Permisos ajustados en rutas locales Docker")

    def chown_paths(self, paths: Iterable[str], action_message: str) -> None:
        existing = [str(self.rel(path)) for path in paths if self.rel(path).exists()]
        if not existing:
            return
        assert self.uid is not None and self.gid is not None
        result = self.run(self.sudo_cmd(["chown", "-R", f"{self.uid}:{self.gid}", *existing]), timeout=180)
        if result.returncode == 0:
            self.action(action_message)
        else:
            self.warn(f"No se pudieron ajustar permisos: {last_line(result.stderr)}")

    def check_ssh_and_vpn(self) -> None:
        self.step("Revisando SSH y tunel QA")
        ssh_config = Path.home() / ".ssh" / "config"
        if ssh_config.exists():
            self.ok("~/.ssh/config existe")
            self.check_ssh_identityfile_paths(ssh_config)
        else:
            self.warn("Falta ~/.ssh/config")

        ssh_profiles = {}
        if self.command_exists("ssh"):
            for alias, expected in SSH_REQUIRED_ALIASES.items():
                ssh_g = self.run(["ssh", "-F", str(ssh_config), "-G", alias], timeout=20)
                if ssh_g.returncode == 0:
                    self.ok(f"Alias SSH {alias} se puede leer con ssh -G")
                    ssh_values = parse_ssh_config_output(ssh_g.stdout)
                    ssh_lists = parse_ssh_config_output_lists(ssh_g.stdout)
                    host = ssh_values.get("hostname", "")
                    port = ssh_values.get("port", "")
                    user = ssh_values.get("user", "")
                    if host == expected["hostname"] and port == expected["port"]:
                        self.ok(f"{alias} apunta a {host}:{port}")
                    elif host and port:
                        self.warn(
                            f"{alias} apunta a {host}:{port}, pero se esperaba "
                            f"{expected['hostname']}:{expected['port']}."
                        )
                    else:
                        self.warn(f"No pude calcular HostName/Port del alias {alias}.")
                    if user:
                        self.info(f"Usuario SSH para {alias}: {user}")
                    identity_files = ssh_lists.get("identityfile", [])
                    existing_identities = [path for path in identity_files if Path(path).exists()]
                    root_identities = [path for path in identity_files if path.startswith("/root/")]
                    ssh_profiles[alias] = {
                        "host": host,
                        "port": port,
                        "user": user,
                        "identities": existing_identities,
                    }
                    if root_identities:
                        self.warn(
                            f"{alias} intenta usar llaves de root: {', '.join(root_identities)}. "
                            "No ejecutes sshuttle con sudo directo."
                        )
                    elif existing_identities:
                        self.ok(f"{alias} tiene llave SSH accesible: {existing_identities[0]}")
                    elif identity_files:
                        self.warn(f"Ninguna llave IdentityFile existe para {alias}: {', '.join(identity_files)}")
                    else:
                        self.warn(f"{alias} no declara IdentityFile; SSH usara llaves por defecto.")
                else:
                    self.warn(f"No pude leer el alias SSH {alias}. Revisa ~/.ssh/config.")
            self.offer_dev_ssh_repair(ssh_config, ssh_profiles)

        vpn_preview = self.run(["make", "--no-print-directory", "-n", "vpn-qa"], timeout=20)
        if vpn_preview.returncode == 0:
            preview = " ".join(vpn_preview.stdout.strip().split())
            if preview.startswith("sudo sshuttle"):
                self.warn("make vpn-qa ejecuta sudo sshuttle; eso puede hacer que SSH busque llaves en /root.")
            elif preview.startswith("sshuttle"):
                self.ok("make vpn-qa ejecuta sshuttle como usuario normal")
                self.info("sshuttle pedira sudo solo para rutas/firewall cuando sea necesario.")
            if "/root/.ssh" in preview:
                self.warn("make vpn-qa contiene rutas /root/.ssh; revisa SSH_CONFIG.")
            elif str(ssh_config) in preview:
                self.ok(f"make vpn-qa usa SSH_CONFIG={ssh_config}")
            self.info("Comando vpn-qa: " + preview)
        else:
            self.warn(f"No pude previsualizar make vpn-qa: {last_line(vpn_preview.stderr or vpn_preview.stdout)}")

        if self.command_exists("sshuttle"):
            self.ok("sshuttle disponible para make vpn-qa")
        else:
            self.warn("sshuttle no esta instalado")

        self.info("make vpn-qa debe quedarse abierto mientras uses servicios remotos de QA.")

    def offer_dev_ssh_repair(self, ssh_config: Path, profiles: Dict[str, Dict[str, object]]) -> None:
        qa = profiles.get("qa")
        dev = profiles.get("dev")
        if qa is None or dev is None:
            return

        qa_identities = qa.get("identities", [])
        dev_identities = dev.get("identities", [])
        if not isinstance(qa_identities, list) or not qa_identities:
            return
        expected = SSH_REQUIRED_ALIASES["dev"]
        if dev.get("host") == expected["hostname"] and dev.get("port") == expected["port"] and dev_identities:
            return

        qa_identity = qa_identities[0]
        qa_user = qa.get("user", "")
        if not isinstance(qa_identity, str) or not qa_identity:
            return
        if not isinstance(qa_user, str) or not qa_user:
            self.warn("QA tiene una llave accesible, pero no pude determinar su usuario SSH para configurar dev.")
            return

        self.info(f"QA usa la llave {qa_identity}; se puede reutilizar para configurar el alias dev.")
        if not self.ask("Corregir el alias SSH dev con HostName, puerto, usuario y llave de qa?"):
            return
        try:
            original = self.read_text(ssh_config)
        except OSError as exc:
            self.warn(f"No pude leer ~/.ssh/config para corregir dev: {exc}")
            return

        fixed = upsert_ssh_host(
            original,
            "dev",
            {
                "hostname": expected["hostname"],
                "user": qa_user,
                "port": expected["port"],
                "identityfile": qa_identity,
                "identitiesonly": "yes",
            },
        )
        if fixed is None:
            self.warn("El alias dev comparte un bloque Host con otros aliases; corrigelo manualmente para no alterar los demas.")
            return

        backup = ssh_config.with_name("config.redgps.bak")
        try:
            shutil.copy2(ssh_config, backup)
            self.write_text(ssh_config, fixed)
        except OSError as exc:
            self.warn(f"No pude actualizar ~/.ssh/config: {exc}")
            return
        self.action(f"Alias SSH dev configurado como qa; respaldo creado en {backup}")

        verification = self.run(["ssh", "-F", str(ssh_config), "-G", "dev"], timeout=20)
        values = parse_ssh_config_output(verification.stdout) if verification.returncode == 0 else {}
        if values.get("hostname") == expected["hostname"] and values.get("port") == expected["port"]:
            self.ok(f"dev ahora apunta a {expected['hostname']}:{expected['port']}")
        else:
            self.warn("No pude confirmar el alias dev despues de actualizar ~/.ssh/config.")

    def check_ssh_identityfile_paths(self, ssh_config: Path) -> None:
        content = self.read_text(ssh_config)
        fixed_content, changes = normalize_ssh_identity_paths(
            content,
            Path.home(),
            SSH_REQUIRED_ALIASES.keys(),
        )
        if not changes:
            self.ok("IdentityFile de dev/qa no usa rutas dependientes de root")
            return

        for change in changes:
            self.warn(change)
        self.info("Usa rutas absolutas para IdentityFile; funcionan igual en Linux, Fedora, Ubuntu, Mint y macOS.")
        if self.ask("Normalizar IdentityFile de dev/qa en ~/.ssh/config?"):
            backup = ssh_config.with_name("config.redgps.bak")
            shutil.copy2(ssh_config, backup)
            self.write_text(ssh_config, fixed_content)
            self.action(f"Normalizado ~/.ssh/config; respaldo creado en {backup}")

    def check_cache_servers(self) -> None:
        self.step("Revisando cache local de servidores")
        env_values = self.parse_env()
        local_value = env_values.get("CACHE_SERVERS_LOCAL_PATH", "docker/var-cache/files/cache_servidores")
        local_dir = Path(local_value)
        if not local_dir.is_absolute():
            local_dir = self.rel(local_value)

        if not local_dir.exists():
            self.warn(f"Falta carpeta de cache de servidores: {local_dir.relative_to(self.root)}")
            if self.ask("Crear carpeta de cache de servidores?"):
                self.ensure_dir(local_dir)

        missing = [name for name in CACHE_SERVER_FILES if not (local_dir / name).exists()]
        invalid = []
        for name in CACHE_SERVER_FILES:
            path = local_dir / name
            if not path.exists():
                continue
            if name == "cache_servers_REGION_DATACENTER.json":
                if not self.read_text(path).strip():
                    invalid.append(name)
                continue
            try:
                json.loads(self.read_text(path))
            except json.JSONDecodeError:
                invalid.append(name)

        if not missing and not invalid:
            self.ok("Cache de servidores completo y con JSON valido")
            return

        if missing:
            preview = ", ".join(missing[:8])
            suffix = "" if len(missing) <= 8 else f" y {len(missing) - 8} mas"
            self.warn(f"Faltan caches de servidores: {preview}{suffix}")
        if invalid:
            self.warn("Caches de servidores con JSON invalido: " + ", ".join(invalid))

        self.info("Sin estos archivos la aplicacion puede responder 404 y registrar NO SE ENCONTRO CACHE.")
        if self.ask("Descargar cache de servidores desde QA con make cache-servers-qa?"):
            self.run_make("cache-servers-qa")
            missing_after = [name for name in CACHE_SERVER_FILES if not (local_dir / name).exists()]
            if missing_after:
                self.warn("Aun faltan caches despues de descargar: " + ", ".join(missing_after[:8]))
            else:
                self.ok("Cache de servidores descargado")

    def check_docker_runtime(self) -> None:
        self.step("Revisando Docker Compose y contenedores")
        if not self.command_exists("docker"):
            self.warn("Omito revision de contenedores porque Docker no esta disponible.")
            return

        config = self.run(["docker", "compose", "config", "--quiet"], timeout=60)
        if config.returncode == 0:
            self.ok("docker compose config --quiet correcto")
        else:
            self.warn(f"docker compose config fallo: {last_line(config.stderr or config.stdout)}")

        ps = self.run(["docker", "compose", "ps"], timeout=30)
        if ps.returncode == 0:
            self.info("Estado actual de contenedores:")
            for line in ps.stdout.strip().splitlines()[:12]:
                self.say(f"    {line}")
        else:
            self.warn(f"No pude ejecutar docker compose ps: {last_line(ps.stderr or ps.stdout)}")
            return

        for service in ["qa_web", "dev_web"]:
            result = self.run(["docker", "compose", "exec", "-T", service, "apache2ctl", "-t"], timeout=30)
            if result.returncode == 0:
                self.ok(f"Apache syntax OK en {service}")
            else:
                msg = last_line(result.stderr or result.stdout)
                self.warn(f"No pude validar Apache en {service}: {msg}")

        qa_mounts_ready = self.check_qa_container_mounts()
        if not qa_mounts_ready:
            self.warn("QA no tiene los archivos de aplicacion esperados dentro del contenedor; Apache devolvera 404.")
            if self.ask("Recrear qa_web y web para aplicar los bind mounts actuales?"):
                if self.recreate_qa_services():
                    qa_mounts_ready = self.check_qa_container_mounts()
            if not qa_mounts_ready:
                self.info("Omito la prueba HTTP hasta que qa_web tenga index.php y sources montados correctamente.")
                return

        session_host = self.qa_session_host()
        qa_dns = self.run(["docker", "exec", "redgps_qa_web", "getent", "hosts", session_host], timeout=20)
        if qa_dns.returncode == 0 and qa_dns.stdout.strip():
            self.ok(f"redgps_qa_web resuelve {session_host}")
        else:
            self.warn(f"redgps_qa_web no resuelve {session_host}.")
            if self.host_resolves(session_host):
                self.info(
                    f"El host local si resuelve {session_host}; si el contenedor no, "
                    "reinicia qa_web/web con el tunel activo."
                )
            else:
                self.warn(f"El host local tampoco resuelve {session_host}. Mantén make vpn-qa abierto en otra terminal.")
            self.report_sshuttle_process()

        self.check_qa_session_service(session_host)
        login_route_ready = self.check_qa_login_route()

        if self.command_exists("curl"):
            backend = self.run(
                [
                    "curl",
                    "-s",
                    "-S",
                    "--max-time",
                    "20",
                    "-o",
                    "/dev/null",
                    "-w",
                    "%{http_code} %{time_total} %{size_download}",
                    "-H",
                    "Host: qa.redgps.local",
                    "http://127.0.0.1:18082/login",
                ],
                timeout=30,
            )
            backend_parts = backend.stdout.strip().split()
            backend_code = backend_parts[0] if backend_parts else ""
            if backend_code:
                detail = " ".join(backend_parts[1:])
                suffix = f" ({detail})" if detail else ""
                self.info(f"Backend QA directo /login responde HTTP {backend_code}{suffix}")
                if backend_code == "404":
                    self.inspect_backend_404(login_route_ready)
                    if self.ask("Regenerar autoload QA, reiniciar qa_web/web y volver a probar /login?"):
                        if self.regenerate_qa_autoload():
                            backend = self.run(
                                [
                                    "curl",
                                    "-s",
                                    "-S",
                                    "--max-time",
                                    "20",
                                    "-o",
                                    "/dev/null",
                                    "-w",
                                    "%{http_code} %{time_total} %{size_download}",
                                    "-H",
                                    "Host: qa.redgps.local",
                                    "http://127.0.0.1:18082/login",
                                ],
                                timeout=30,
                            )
                            backend_parts = backend.stdout.strip().split()
                            backend_code = backend_parts[0] if backend_parts else ""
                            if backend_code in {"200", "302", "401"}:
                                self.ok(f"Backend QA /login responde HTTP {backend_code} despues de regenerar autoload")
                            elif backend_code:
                                self.warn(f"Backend QA /login sigue respondiendo HTTP {backend_code} despues de regenerar autoload.")

            result = self.run(
                [
                    "curl",
                    "-s",
                    "-S",
                    "-k",
                    "--max-time",
                    "20",
                    "-o",
                    "/dev/null",
                    "-w",
                    "%{http_code} %{time_total} %{size_download}",
                    "-H",
                    "Host: qa.redgps.local",
                    "https://127.0.0.1:8001/login",
                ],
                timeout=30,
            )
            parts = result.stdout.strip().split()
            code = parts[0] if parts else ""
            if code in {"200", "302", "401"}:
                self.ok(f"Gateway QA /login responde HTTP {code}")
            elif code == "404":
                if backend_code == "404":
                    self.warn("Gateway QA /login responde HTTP 404 porque el backend QA directo tambien devuelve 404.")
                else:
                    self.warn("Gateway QA /login responde HTTP 404; revisa ruteo del gateway y make logs-qa.")
                self.inspect_recent_qa_logs()
            elif code:
                self.warn(f"Gateway QA /login responde HTTP {code}; revisa make logs-qa.")
                self.inspect_recent_qa_logs()
            else:
                self.warn("No pude probar https://qa.redgps.local:8001/login")

    def check_qa_container_mounts(self) -> bool:
        container = self.compose_service_container("qa_web")
        if not container:
            self.warn("No pude identificar el contenedor de qa_web para revisar sus mounts.")
            return False
        mount_sources = self.container_mount_sources(container)
        checks = [
            (
                "index QA montado",
                self.rel("qa/redgps/public/index.php"),
                self.rel("qa/redgps"),
                "/var/www/html/web/redgps",
                "test -f /var/www/html/web/redgps/public/index.php",
            ),
            (
                "sources QA montado",
                self.rel("qa/redgps/sources"),
                self.rel("qa/redgps"),
                "/var/www/html/web/redgps",
                "test -d /var/www/html/web/redgps/sources",
            ),
            (
                "commons QA montado",
                self.rel("qa/commons"),
                self.rel("qa/commons"),
                "/home/redgps/commons",
                "test -d /home/redgps/commons",
            ),
            (
                "cache servidores montado",
                self.rel("docker/var-cache/files/cache_servidores"),
                self.rel("docker/var-cache"),
                "/var/cache",
                "test -d /var/cache/files/cache_servidores",
            ),
            (
                "cache MASTER visible en contenedor",
                self.rel("docker/var-cache/files/cache_servidores/cache_servers_MASTER.json"),
                self.rel("docker/var-cache"),
                "/var/cache",
                "test -s /var/cache/files/cache_servidores/cache_servers_MASTER.json",
            ),
        ]
        ready = True
        for label, host_path, expected_mount_source, mount_destination, shell_cmd in checks:
            if not host_path.exists():
                self.warn(f"Falta {host_path.relative_to(self.root)} en el host; no se puede montar en qa_web.")
                ready = False
                continue
            result = self.run(["docker", "exec", container, "sh", "-lc", shell_cmd], timeout=15)
            if result.returncode == 0:
                self.ok(label)
            else:
                actual_source = mount_sources.get(mount_destination)
                if actual_source:
                    self.warn(
                        f"{label} no fue validado dentro de qa_web. Mount actual: {actual_source} -> "
                        f"{mount_destination}; se esperaba {expected_mount_source}."
                    )
                else:
                    self.warn(f"{label} no fue validado dentro de qa_web; falta el mount {mount_destination}.")
                ready = False
        return ready

    def qa_session_host(self) -> str:
        region_file = self.rel("docker/var-cache/files/cache_servidores/cache_servers_REGION_DATACENTER.json")
        try:
            region = self.read_text(region_file).strip().lower()
        except OSError:
            region = ""
        return "sesionese1.service24gps.com" if region == "fra" else "sesiones.redgps.com"

    def check_qa_session_service(self, host: str) -> None:
        script = (
            '$socket = @fsockopen($argv[1], 3306, $errno, $error, 5); '
            'if (!$socket) { fwrite(STDERR, $error . " (" . $errno . ")"); exit(1); } '
            'fclose($socket);'
        )
        result = self.run(
            ["docker", "compose", "exec", "-T", "qa_web", "php", "-r", script, "--", host],
            timeout=15,
        )
        if result.returncode == 0:
            self.ok(f"qa_web puede conectar a {host}:3306 para sesiones")
            return
        detail = last_line(result.stderr or result.stdout)
        self.warn(f"qa_web no puede conectar a {host}:3306 para sesiones: {detail or 'sin detalle'}")
        self.info("Mantén make vpn-qa abierto en otra terminal y ejecuta docker compose restart qa_web web.")
        self.report_sshuttle_process()

    def qa_login_route_status(self) -> Optional[Dict[str, object]]:
        script = r'''
$system = array();
require '/var/www/html/web/redgps/sources/routes.php';
$route = isset($system['routes']['/login']) && is_array($system['routes']['/login'])
    ? $system['routes']['/login'] : array();
$controller = isset($route['content']) ? (string) $route['content'] : '';
$action = isset($route['action']) ? (string) $route['action'] : '';
$cacheFile = '/var/cache/files/autoloads/autoload_redgps';
$classes = is_file($cacheFile) ? include $cacheFile : null;
$controllerFile = is_array($classes) && isset($classes[strtolower($controller)])
    ? $classes[strtolower($controller)] : '';
$source = is_string($controllerFile) && is_file($controllerFile)
    ? file_get_contents($controllerFile) : false;
echo json_encode(array(
    'route_exists' => !empty($route),
    'controller' => $controller,
    'action' => $action,
    'cache_exists' => is_array($classes),
    'controller_file_exists' => $source !== false,
    'action_exists' => $source !== false
        && preg_match('/function\\s+' . preg_quote($action, '/') . '\\s*\\(/i', $source) === 1,
));
'''
        result = self.run(
            ["docker", "compose", "exec", "-T", "qa_web", "php", "-r", script],
            timeout=30,
        )
        if result.returncode != 0:
            detail = last_line(result.stderr or result.stdout)
            self.warn(f"No pude validar la ruta /login dentro de qa_web: {detail or 'sin detalle'}")
            return None
        try:
            data = json.loads(result.stdout.strip())
        except json.JSONDecodeError:
            self.warn("No pude interpretar la validacion de ruta /login dentro de qa_web.")
            self.emit_output_tail(result.stdout, result.stderr, limit=8)
            return None
        return data if isinstance(data, dict) else None

    def qa_login_route_is_ready(self, status: Dict[str, object]) -> bool:
        return bool(
            status.get("route_exists")
            and status.get("controller")
            and status.get("action")
            and status.get("cache_exists")
            and status.get("controller_file_exists")
            and status.get("action_exists")
        )

    def check_qa_login_route(self) -> bool:
        status = self.qa_login_route_status()
        if status is None:
            return False

        if self.qa_login_route_is_ready(status):
            self.ok(
                "Ruta QA /login y controlador "
                f"{status['controller']}::{status['action']} disponibles en el autoload"
            )
            return True

        cache_invalid = (
            not bool(status.get("cache_exists"))
            or not bool(status.get("controller_file_exists"))
        )
        if cache_invalid:
            self.info("La cache de autoload QA no contiene un archivo util para la ruta /login.")
            if self.ask("Regenerar el autoload QA dentro de qa_web y volver a validar /login?"):
                if self.run_make("cache-autoload-qa"):
                    status = self.qa_login_route_status()
                    if status is not None and self.qa_login_route_is_ready(status):
                        self.ok("Autoload QA regenerado; /login ya tiene controlador y accion disponibles")
                        return True

        if not status.get("route_exists"):
            self.warn("QA no define la ruta /login en sources/routes.php; actualiza el repositorio qa/redgps.")
        elif not status.get("controller") or not status.get("action"):
            self.warn("La ruta QA /login no define controlador y accion validos.")
        elif cache_invalid:
            self.warn("Autoload QA invalido para /login. Ejecuta make cache-autoload-qa y vuelve a iniciar el asistente.")
        else:
            self.warn(
                f"El controlador QA {status['controller']} no implementa la accion {status['action']} de /login."
            )
        return False

    def regenerate_qa_autoload(self) -> bool:
        if not self.run_make("cache-autoload-qa"):
            return False
        result = self.run(["docker", "compose", "restart", "qa_web", "web"], timeout=90)
        if result.returncode == 0:
            self.action("Reiniciados qa_web y web despues de regenerar el autoload QA")
            return True
        self.warn(f"Autoload QA regenerado, pero no pude reiniciar qa_web/web: {last_line(result.stderr or result.stdout)}")
        return True

    def compose_service_container(self, service: str) -> str:
        result = self.run(["docker", "compose", "ps", "-q", service], timeout=20)
        container = first_nonempty_line(result.stdout) if result.returncode == 0 else ""
        if container:
            return container
        return f"redgps_{service}"

    def container_mount_sources(self, container: str) -> Dict[str, str]:
        result = self.run(["docker", "inspect", container], timeout=20)
        if result.returncode != 0:
            return {}
        try:
            details = json.loads(result.stdout)
        except json.JSONDecodeError:
            return {}
        if not details or not isinstance(details[0], dict):
            return {}
        mounts = details[0].get("Mounts", [])
        if not isinstance(mounts, list):
            return {}
        return {
            mount["Destination"]: mount["Source"]
            for mount in mounts
            if isinstance(mount, dict) and mount.get("Destination") and mount.get("Source")
        }

    def recreate_qa_services(self) -> bool:
        result = self.run(["docker", "compose", "up", "-d", "--force-recreate", "qa_web", "web"], timeout=180)
        if result.returncode == 0:
            self.action("Recreados qa_web y web para actualizar sus bind mounts")
            return True
        self.warn(f"No se pudieron recrear qa_web y web: {last_line(result.stderr or result.stdout)}")
        self.emit_output_tail(result.stdout, result.stderr, limit=18)
        return False

    def inspect_backend_404(self, login_route_ready: bool) -> None:
        result = self.run(
            [
                "curl",
                "-s",
                "-S",
                "--max-time",
                "20",
                "-i",
                "-H",
                "Host: qa.redgps.local",
                "http://127.0.0.1:18082/login",
            ],
            timeout=30,
        )
        response = (result.stdout or "") + "\n" + (result.stderr or "")
        first = first_nonempty_line(response)
        snippet = html_to_text_snippet(response, limit=220)
        if first:
            self.info(f"Primera linea backend QA: {first}")
        if snippet:
            self.info(f"Fragmento respuesta backend QA: {snippet}")
        if "Page not found" in response or "Not Found 404" in response or "error404" in response or "pagenotfound" in response:
            if login_route_ready:
                self.warn(
                    "El 404 de /login es generado por PHP aunque su ruta y autoload son validos. "
                    "Ejecuta make cache-autoload-qa, reinicia qa_web/web y vuelve a probar."
                )
            else:
                self.warn("El 404 de /login parece generado por la aplicacion PHP; revisa los avisos de ruta y autoload QA.")

    def host_resolves(self, host: str) -> bool:
        try:
            socket.gethostbyname(host)
            return True
        except OSError:
            return False

    def report_sshuttle_process(self) -> None:
        if not self.command_exists("pgrep"):
            self.info("No pude revisar procesos sshuttle porque pgrep no esta disponible.")
            return
        result = self.run(["pgrep", "-af", "sshuttle"], timeout=10)
        if result.returncode == 0 and result.stdout.strip():
            first = result.stdout.strip().splitlines()[0]
            self.info(f"Proceso sshuttle detectado: {first}")
        else:
            self.warn("No detecte un proceso sshuttle activo. Ejecuta make vpn-qa y dejalo abierto.")

    def inspect_recent_qa_logs(self) -> None:
        result = self.run(["docker", "compose", "logs", "--since=5m", "--tail=120", "qa_web"], timeout=30)
        if result.returncode != 0:
            result = self.run(["docker", "compose", "logs", "--tail=80", "qa_web"], timeout=30)
        logs = (result.stdout or "") + "\n" + (result.stderr or "")
        if not logs.strip():
            self.info("No pude leer logs recientes de qa_web.")
            return

        if "SetEnvIfNoCaseHeader name regex could not be compiled" in logs or "Accept-EncodXng" in logs:
            self.warn("Logs QA muestran .htaccess viejo. Actualiza repos QA con make app-repos-pull-qa.")
            if self.ask("Ejecutar make app-repos-pull-qa ahora?"):
                self.run_make("app-repos-pull-qa")
        if "NO SE ENCONTRO CACHE" in logs or "NO SE ENCUENTRA CACHE DE SERVIDORES" in logs:
            self.warn("Logs QA muestran cache de servidores faltante. Ejecuta make cache-servers-qa.")
            if self.ask("Ejecutar make cache-servers-qa ahora?"):
                self.run_make("cache-servers-qa")
        dns_patterns = [
            "php_network_getaddresses",
            "getaddrinfo failed",
            "Temporary failure in name resolution",
            "Name or service not known",
            "Connection refused",
            "SQLSTATE[HY000] [2002]",
        ]
        if any(pattern in logs for pattern in dns_patterns):
            self.warn("Logs QA muestran problema de DNS/conexion remota. Mantén make vpn-qa abierto y reinicia qa_web/web.")
        php_patterns = [
            "PHP Fatal error",
            "PHP Parse error",
            "failed to open stream",
            "Failed opening required",
            "Class '",
            "Class not found",
            "Call to undefined",
        ]
        if any(pattern in logs for pattern in php_patterns):
            self.warn("Logs QA muestran errores PHP/includes. Revisa que los repos QA esten actualizados y montados.")
        if not any(pattern in logs for pattern in dns_patterns + php_patterns) and " 404 " in logs:
            self.info("No detecte patron conocido en logs recientes; ultimas lineas utiles de qa_web:")
            self.emit_output_tail(result.stdout, result.stderr, limit=12)

    def print_summary(self) -> int:
        self.step("Resumen")
        if self.actions_taken:
            self.say("Acciones realizadas:")
            for action in self.actions_taken:
                self.say(f"  - {action}")
        else:
            self.say("No se aplicaron cambios.")

        if self.warnings:
            self.say("")
            self.say("Avisos pendientes:")
            for warning in self.warnings:
                self.say(f"  - {warning}")

        if self.failures:
            self.say("")
            self.say("Errores:")
            for failure in self.failures:
                self.say(f"  - {failure}")
            return 1 if self.args.strict else 0

        return 1 if (self.args.strict and self.warnings) else 0

    def run_all(self) -> int:
        self.say("REDGPS Docker setup wizard")
        self.say(f"Raiz del proyecto: {self.root}")
        if self.args.dry_run or self.args.doctor_only:
            self.say("Modo revision: no se modificaran archivos ni configuraciones del sistema.")

        self.check_os_and_tools()
        self.check_project_structure()
        self.check_env_files()
        self.check_hosts()
        self.check_certs()
        self.check_vhosts_and_htaccess()
        self.check_permissions()
        self.check_ssh_and_vpn()
        self.check_cache_servers()
        self.check_docker_runtime()
        return self.print_summary()


def walk_limited(start: Path, limit: int) -> Iterable[Path]:
    yielded = 0
    for root, dirs, files in os.walk(start):
        dirs[:] = [d for d in dirs if d not in {".git", "node_modules", "vendor"}]
        root_path = Path(root)
        for name in dirs + files:
            yield root_path / name
            yielded += 1
            if yielded >= limit:
                return


def last_line(text: str) -> str:
    lines = [line.strip() for line in text.splitlines() if line.strip()]
    return lines[-1] if lines else ""


def first_nonempty_line(text: str) -> str:
    for line in text.splitlines():
        stripped = line.strip()
        if stripped:
            return stripped
    return ""


def nss_certificate_nicknames(text: str) -> Iterable[str]:
    for line in text.splitlines():
        match = re.match(r"^(.+?)\s{2,}[A-Za-z]*,[A-Za-z]*,[A-Za-z]*\s*$", line)
        if match:
            yield match.group(1).rstrip()


def certificate_fingerprint(certificate: str) -> Optional[str]:
    try:
        return hashlib.sha256(ssl.PEM_cert_to_DER_cert(certificate)).hexdigest()
    except ValueError:
        return None


def html_to_text_snippet(text: str, *, limit: int = 220) -> str:
    separator = "\r\n\r\n" if "\r\n\r\n" in text else "\n\n"
    body = text.split(separator, 1)[1] if separator in text else text
    body = re.sub(r"<script\b[^>]*>.*?</script>", " ", body, flags=re.IGNORECASE | re.DOTALL)
    body = re.sub(r"<style\b[^>]*>.*?</style>", " ", body, flags=re.IGNORECASE | re.DOTALL)
    body = re.sub(r"<[^>]+>", " ", body)
    body = " ".join(body.split())
    return body[:limit]


def parse_ssh_config_output(text: str) -> Dict[str, str]:
    values: Dict[str, str] = {}
    for line in text.splitlines():
        parts = line.strip().split(None, 1)
        if len(parts) == 2:
            values[parts[0].lower()] = parts[1]
    return values


def parse_ssh_config_output_lists(text: str) -> Dict[str, List[str]]:
    values: Dict[str, List[str]] = {}
    for line in text.splitlines():
        parts = line.strip().split(None, 1)
        if len(parts) == 2:
            values.setdefault(parts[0].lower(), []).append(parts[1])
    return values


def upsert_ssh_host(text: str, alias: str, values: Dict[str, str]) -> Optional[str]:
    lines = text.splitlines(keepends=True)
    start: Optional[int] = None
    for index, raw_line in enumerate(lines):
        parts = raw_line.strip().split(None, 1)
        if len(parts) != 2 or parts[0].lower() != "host":
            continue
        patterns = parts[1].split()
        if alias.lower() not in {pattern.lower() for pattern in patterns}:
            continue
        if len(patterns) != 1:
            return None
        start = index
        break

    newline = "\r\n" if "\r\n" in text else "\n"
    block = ssh_host_block(alias, values, newline)
    if start is None:
        prefix = text
        if prefix and not prefix.endswith(("\n", "\r")):
            prefix += newline
        if prefix and not prefix.endswith(newline * 2):
            prefix += newline
        return prefix + block

    end = len(lines)
    for index in range(start + 1, len(lines)):
        parts = lines[index].strip().split(None, 1)
        if parts and parts[0].lower() == "host":
            end = index
            break

    managed = {"hostname", "user", "port", "identityfile", "identitiesonly"}
    preserved = []
    for raw_line in lines[start + 1 : end]:
        parts = raw_line.strip().split(None, 1)
        if parts and parts[0].lower() in managed:
            continue
        preserved.append(raw_line)
    return "".join([*lines[:start], block, *preserved, *lines[end:]])


def ssh_host_block(alias: str, values: Dict[str, str], newline: str) -> str:
    labels = [
        ("hostname", "HostName"),
        ("user", "User"),
        ("port", "Port"),
        ("identityfile", "IdentityFile"),
        ("identitiesonly", "IdentitiesOnly"),
    ]
    lines = [f"Host {alias}{newline}"]
    lines.extend(f"    {label} {values[key]}{newline}" for key, label in labels if values.get(key))
    return "".join(lines)


def normalize_ssh_identity_paths(
    text: str,
    home: Path,
    aliases: Iterable[str],
) -> Tuple[str, List[str]]:
    target_aliases = set(aliases)
    current_aliases: List[str] = []
    changes: List[str] = []
    output: List[str] = []

    for raw_line in text.splitlines(keepends=True):
        line = raw_line.rstrip("\r\n")
        newline = raw_line[len(line):]
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            output.append(raw_line)
            continue

        parts = stripped.split(None, 1)
        key = parts[0].lower()
        value = parts[1].strip() if len(parts) == 2 else ""

        if key == "host":
            patterns = value.split()
            current_aliases = [alias for alias in target_aliases if alias in patterns]
            output.append(raw_line)
            continue

        if key != "identityfile" or not current_aliases or not value:
            output.append(raw_line)
            continue

        quote = value[0] if value[:1] in {"'", '"'} else ""
        unquoted = value.strip("'\"")
        normalized = normalize_identity_value(unquoted, home)
        if normalized == unquoted:
            output.append(raw_line)
            continue

        indent = line[: len(line) - len(line.lstrip())]
        replacement_value = f"{quote}{normalized}{quote}" if quote else normalized
        output.append(f"{indent}IdentityFile {replacement_value}{newline}")
        aliases_text = ", ".join(current_aliases)
        changes.append(f"IdentityFile de {aliases_text} usa {value}; se normalizara a {normalized}")

    return "".join(output), changes


def normalize_identity_value(value: str, home: Path) -> str:
    if value == "~":
        return str(home)
    if value.startswith("~/"):
        return str(home / value[2:])
    if value.startswith("$HOME/"):
        return str(home / value[6:])
    if value.startswith("${HOME}/"):
        return str(home / value[8:])
    if value.startswith("%d/"):
        return str(home / value[3:])
    path = Path(value)
    if path.is_absolute() or value.startswith("%"):
        return value
    return str(home / value)


def parse_args(argv: Optional[Sequence[str]] = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Instalador asistido para el entorno Docker local REDGPS.",
    )
    parser.add_argument("--dry-run", action="store_true", help="Muestra lo que haria sin aplicar cambios.")
    parser.add_argument("--doctor-only", action="store_true", help="Solo diagnostica; equivalente practico a no modificar.")
    parser.add_argument("--yes", action="store_true", help="Acepta automaticamente reparaciones no destructivas.")
    parser.add_argument("--skip-sudo", action="store_true", help="No ejecuta acciones que requieran sudo.")
    parser.add_argument("--strict", action="store_true", help="Devuelve codigo 1 si quedan avisos o errores.")
    return parser.parse_args(argv)


def main(argv: Optional[Sequence[str]] = None) -> int:
    args = parse_args(argv)
    wizard = Wizard(args)
    return wizard.run_all()


if __name__ == "__main__":
    raise SystemExit(main())
